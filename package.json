{
  "name": "zamproject",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.3",
  "workspaces": [
    "backend",
    "frontend",
    "admin",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter backend run dev",
    "dev:web": "pnpm --filter frontend run dev",
    "dev:admin": "pnpm --filter admin run dev",
    "build": "pnpm -r run build",
    "deploy:api": "pnpm --filter backend run deploy",
    "deploy:web": "pnpm --filter frontend run deploy",
    "deploy:admin": "pnpm --filter admin run deploy",
    "deploy": "pnpm run build && pnpm run deploy:api && pnpm run deploy:web"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  }
}
