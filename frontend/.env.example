# Supabase — required for auth and database features
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Hono backend API base URL
# Dev: use /api (Vite proxies to localhost:8787 — works from any local URL)
# Prod: full Worker URL
VITE_API_BASE_URL=/api

# Local dev only — skip OTP login; must match backend DEV_BYPASS_MEMBER_ID
VITE_DEV_MEMBER_ID=10000000-0000-0000-0000-000000000001
VITE_DEV_MEMBER_EMAIL=operator@spacex.hq
